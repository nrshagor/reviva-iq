<odoo>
    <record id="view_revivaiq_analytics_snapshot_list" model="ir.ui.view">
        <field name="name">revivaiq.analytics.snapshot.list</field>
        <field name="model">revivaiq.analytics.snapshot</field>
        <field name="arch" type="xml">
            <list string="Analytics Snapshots">
                <field name="name"/>
                <field name="snapshot_date"/>
                <field name="snapshot_type"/>
                <field name="dead_stock_count"/>
                <field name="dead_stock_value" widget="monetary"/>
                <field name="inactive_customer_count"/>
                <field name="recovery_opportunity_value" widget="monetary"/>
                <field name="total_revenue_risk" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_revivaiq_analytics_snapshot_form" model="ir.ui.view">
        <field name="name">revivaiq.analytics.snapshot.form</field>
        <field name="model">revivaiq.analytics.snapshot</field>
        <field name="arch" type="xml">
            <form string="Analytics Snapshot">
                <sheet>
                    <group string="Snapshot Info" col="2">
                        <field name="name"/>
                        <field name="snapshot_date"/>
                        <field name="company_id" readonly="1"/>
                        <field name="snapshot_type"/>
                        <field name="state"/>
                    </group>

                    <group string="Dead Stock Summary" col="2">
                        <field name="dead_stock_count"/>
                        <field name="dead_stock_value" widget="monetary"/>
                    </group>

                    <group string="Customer Recovery Summary" col="2">
                        <field name="inactive_customer_count"/>
                        <field name="customer_recovery_count"/>
                        <field name="high_score_customer_count"/>
                        <field name="recovery_opportunity_value" widget="monetary"/>
                    </group>

                    <group string="Revenue Risk" col="2">
                        <field name="high_risk_dead_stock_count"/>
                        <field name="total_revenue_risk" widget="monetary"/>
                        <field name="currency_id" invisible="1"/>
                    </group>

                    <group string="Note">
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_revivaiq_analytics_snapshot_search" model="ir.ui.view">
        <field name="name">revivaiq.analytics.snapshot.search</field>
        <field name="model">revivaiq.analytics.snapshot</field>
        <field name="arch" type="xml">
            <search string="Search Analytics Snapshots">
                <field name="name"/>
                <field name="snapshot_date"/>
                <field name="snapshot_type"/>
                <field name="state"/>

                <filter string="Manual" name="manual" domain="[('snapshot_type', '=', 'manual')]"/>
                <filter string="System" name="system" domain="[('snapshot_type', '=', 'system')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>

                <group expand="0" string="Group By">
                    <filter string="Snapshot Type" name="group_snapshot_type" context="{'group_by': 'snapshot_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Snapshot Date" name="group_snapshot_date" context="{'group_by': 'snapshot_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_revivaiq_analytics_snapshot" model="ir.actions.act_window">
        <field name="name">Analytics Snapshots</field>
        <field name="res_model">revivaiq.analytics.snapshot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_revivaiq_analytics_snapshot_search"/>
    </record>
</odoo>