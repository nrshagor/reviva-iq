<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_revivaiq_dashboard_list" model="ir.ui.view">
        <field name="name">revivaiq.dashboard.list</field>
        <field name="model">revivaiq.dashboard</field>
        <field name="arch" type="xml">
            <list string="RevivaIQ Overview">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_revivaiq_dashboard_form" model="ir.ui.view">
        <field name="name">revivaiq.dashboard.form</field>
        <field name="model">revivaiq.dashboard</field>
        <field name="arch" type="xml">
            <form string="RevivaIQ Dashboard" create="0" delete="0">
                <header>
                    <button name="action_open_dead_stock_analysis_wizard"
                            string="Run Dead Stock"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_open_customer_recovery_wizard"
                            string="Run Customer Recovery"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_open_snapshot_generation_wizard"
                            string="Generate Snapshot"
                            type="object"
                            class="btn-secondary"/>
                </header>

                <sheet class="o_form_sheet_full_width">
                    <field name="currency_id" invisible="1"/>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <p class="text-muted">
                            Revenue recovery summary for dead stock, inactive customers, and analytics snapshots.
                        </p>
                    </div>

                    <div class="row">
                        <div class="col-lg-4 col-md-12">
                            <group string="Dead Stock Summary">
                                <field name="dead_stock_days_threshold" readonly="1"/>
                                <field name="dead_stock_count" readonly="1"/>
                                <field name="dead_stock_total_quantity" readonly="1"/>
                                <field name="dead_stock_total_sold_quantity" readonly="1"/>
                                <field name="dead_stock_total_risk_value" readonly="1"/>
                                <field name="last_dead_stock_run" readonly="1"/>
                                <button name="action_open_dead_stock"
                                        string="View Dead Stock Details"
                                        type="object"
                                        class="btn-secondary"/>
                            </group>
                        </div>

                        <div class="col-lg-4 col-md-12">
                            <group string="Customer Recovery Summary">
                                <field name="customer_inactivity_days_threshold" readonly="1"/>
                                <field name="inactive_customer_count" readonly="1"/>
                                <field name="high_score_customer_count" readonly="1"/>
                                <field name="customer_recovery_value" readonly="1"/>
                                <field name="last_customer_recovery_run" readonly="1"/>
                                <button name="action_open_customer_insights"
                                        string="View Customer Insights"
                                        type="object"
                                        class="btn-secondary"/>
                            </group>
                        </div>

                        <div class="col-lg-4 col-md-12">
                            <group string="Analytics Snapshot Summary">
                                <field name="latest_snapshot_count" readonly="1"/>
                                <field name="latest_total_revenue_risk" readonly="1"/>
                                <field name="last_snapshot_run" readonly="1"/>
                                <field name="last_snapshot_dead_stock_count" readonly="1"/>
                                <field name="last_snapshot_customer_recovery_count" readonly="1"/>
                                <button name="action_open_analytics_snapshots"
                                        string="View Snapshot History"
                                        type="object"
                                        class="btn-secondary"/>
                            </group>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_revivaiq_dashboard" model="ir.actions.act_window">
        <field name="name">RevivaIQ Dashboard</field>
        <field name="res_model">revivaiq.dashboard</field>
        <field name="view_mode">form,list</field>
        <field name="res_id" ref="revivaiq_dashboard_default"/>
    </record>

    <menuitem id="menu_revivaiq_root"
              name="RevivaIQ"
              sequence="10"
              web_icon="revivaiq_base,static/description/icon.png"/>

    <menuitem id="menu_revivaiq_dashboard"
              name="Dashboard"
              parent="menu_revivaiq_root"
              action="action_revivaiq_dashboard"
              sequence="10"/>

    <menuitem id="menu_revivaiq_intelligence"
              name="Intelligence"
              parent="menu_revivaiq_root"
              sequence="20"/>

    <menuitem id="menu_revivaiq_dead_stock"
              name="Dead Stock"
              parent="menu_revivaiq_intelligence"
              action="action_revivaiq_dead_stock"
              sequence="10"/>

    <menuitem id="menu_revivaiq_customer_insight"
              name="Customer Insights"
              parent="menu_revivaiq_intelligence"
              action="action_revivaiq_customer_insight"
              sequence="20"/>

    <menuitem id="menu_revivaiq_analytics_snapshot"
              name="Analytics Snapshots"
              parent="menu_revivaiq_intelligence"
              action="action_revivaiq_analytics_snapshot"
              sequence="30"/>
</odoo>